<Window x:Class="AlamsServerConsole.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ALAMS Command Center — Administrative Management Console" 
        Height="760" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A"
        Closing="Window_Closing">

    
    <Window.Resources>
        <!-- Custom button template for sidebar navigation -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="15,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" BorderThickness="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Rectangle x:Name="activeBar" Grid.Column="0" Fill="#F43F5E" Width="4" Height="20" HorizontalAlignment="Left" Visibility="Collapsed"/>
                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT COLUMN: SIDEBAR NAVIGATION -->
        <Border Grid.Column="0" Background="#020617" BorderBrush="#1E293B" BorderThickness="0,0,1,0">
            <Grid Margin="15,20,15,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Branding -->
                <StackPanel Grid.Row="0" Margin="5,0,5,25">
                    <TextBlock Text="ALAMS COMMAND" Foreground="#F43F5E" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="CENTER" Foreground="#94A3B8" FontSize="12" FontWeight="SemiBold" Margin="0,2,0,0"/>
                    <Border Background="#1E293B" Height="1" Margin="0,15,0,0"/>
                </StackPanel>

                <!-- Navigation List -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavOpsBtn" Content="⚡ Operations Center" Style="{StaticResource SidebarButtonStyle}" Click="NavOpsBtn_Click"/>
                    <Button x:Name="NavFirewallBtn" Content="🛡️ Windows Firewall" Style="{StaticResource SidebarButtonStyle}" Click="NavFirewallBtn_Click"/>
                    <Button x:Name="NavBackupBtn" Content="💾 Backup &amp; Recovery" Style="{StaticResource SidebarButtonStyle}" Click="NavBackupBtn_Click"/>
                    <Button x:Name="NavWebBtn" Content="🌐 Embedded Web Panel" Style="{StaticResource SidebarButtonStyle}" Click="NavWebBtn_Click"/>
                </StackPanel>

                <!-- Footer Status Info -->
                <StackPanel Grid.Row="2" Margin="5,0,5,0">
                    <Border Background="#1E293B" Height="1" Margin="0,0,0,15"/>
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="SCSIT Administrator" Foreground="#F8FAFC" FontSize="12.5" FontWeight="Bold"/>
                            <TextBlock Text="Local Deployment" Foreground="#64748B" FontSize="11" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border x:Name="IndicatorDot" Width="10" Height="10" CornerRadius="5" Background="#EF4444" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect x:Name="IndicatorDotGlow" BlurRadius="6" Color="#EF4444" ShadowDepth="0" Opacity="0.8"/>
                            </Border.Effect>
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- RIGHT COLUMN: MAIN WORKSPACE CONTAINER -->
        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Ribbon Stats -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="WorkspaceHeaderTitle" Text="Operations Center" Foreground="#F8FAFC" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Central command status monitoring and diagnostics" Foreground="#64748B" FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#1E293B" CornerRadius="8" Padding="12,8" Margin="0,0,12,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Clients: " Foreground="#94A3B8" FontSize="12.5" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TopClientsCount" Text="0" Foreground="#10B981" FontSize="12.5" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1E293B" CornerRadius="8" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Sessions: " Foreground="#94A3B8" FontSize="12.5" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TopSessionsCount" Text="0" Foreground="#38BDF8" FontSize="12.5" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Workspaces TabControl (Hidden headers, programmatically switched) -->
            <TabControl Grid.Row="1" x:Name="MainTabControl" Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.Resources>

                <!-- TAB 1: OPERATIONS CENTER -->
                <TabItem Header="Ops">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Panel: Controls and Health -->
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <!-- Service Power Operations Card -->
                            <Border Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="SERVER PROCESS LIFE-CYCLE" Foreground="#F43F5E" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                                    
                                    <Button x:Name="StartServerBtn" Content="▶ Start Service" Background="#10B981" Foreground="#FFFFFF" FontWeight="Bold" Height="40" Margin="0,0,0,10" Click="StartServerBtn_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>
                                    
                                    <Button x:Name="StopServerBtn" Content="⏹ Stop Service" Background="#F43F5E" Foreground="#FFFFFF" FontWeight="Bold" Height="40" Margin="0,0,0,10" Click="StopServerBtn_Click" Cursor="Hand" BorderThickness="0" IsEnabled="False">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>

                                    <Button x:Name="RestartServerBtn" Content="🔄 Restart Service" Background="#1E293B" Foreground="#38BDF8" BorderBrush="#38BDF8" BorderThickness="1" FontWeight="Bold" Height="40" Click="RestartServerBtn_Click" Cursor="Hand" IsEnabled="False">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>

                                    <CheckBox x:Name="AutoHealCheckBox" Content="🛡️ Enable Auto-Healing (Auto-Start)" Foreground="#94A3B8" FontWeight="SemiBold" Margin="0,12,0,4" IsChecked="True" Cursor="Hand" Checked="AutoHeal_Checked" Unchecked="AutoHeal_Unchecked"/>

                                    <Button x:Name="ForceShutdownAllBtn" Content="🛑 Remote Shutdown All PCs" Background="#7F1D1D" Foreground="#FCA5A5" FontWeight="Bold" Height="40" Margin="0,8,0,0" Click="ForceShutdownAllBtn_Click" Cursor="Hand" BorderThickness="0">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Network Port & Database Card -->
                            <Border Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="INTEGRATION METRICS" Foreground="#F43F5E" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                                    
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="Database Link:" Foreground="#94A3B8" FontSize="13"/>
                                        <TextBlock x:Name="DbStatusText" Text="UNKNOWN" Foreground="#EF4444" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                    
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock Text="API Endpoint Port:" Foreground="#94A3B8" FontSize="13"/>
                                        <TextBlock Text="5000" Foreground="#F8FAFC" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <Grid>
                                        <TextBlock Text="Discovery Beacon:" Foreground="#94A3B8" FontSize="13"/>
                                        <TextBlock Text="ACTIVE (35200)" Foreground="#10B981" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right Panel: Translucent scrolling log console -->
                        <Border Grid.Column="1" Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="15">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="SERVER STDOUT CONSOLE OUTPUT LOG" Foreground="#64748B" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                                    <TextBox x:Name="LogTextBox" Background="Transparent" Foreground="#38BDF8" BorderThickness="0" TextWrapping="Wrap" IsReadOnly="True" FontFamily="Consolas" FontSize="12.5" Text="[COMMAND CENTER INITIALIZED] Click 'Start Service' to spin up the Node.js backend.&#x0a;"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 2: WINDOWS FIREWALL MANAGER -->
                <TabItem Header="Firewall">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Actions Toolbar & Presets -->
                        <Border Grid.Row="0" Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                    <TextBlock Text="SYSTEM DEFENSE PRESETS" Foreground="#F43F5E" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Quickly apply or revert standard firewall profiles for ALAMS Central Server (Ports 5000, 3000, 5432, 80, 443, 35200, ICMP)." Foreground="#94A3B8" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                    <WrapPanel>
                                        <Button Content="🛡️ Apply Server Firewall Preset" Height="36" Padding="12,0" Background="#10B981" Foreground="#FFFFFF" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,10" Click="ApplyFirewallRules_Click" Cursor="Hand">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                        </Button>
                                        <Button Content="🚫 Remove All ALAMS Rules" Height="36" Padding="12,0" Background="#F43F5E" Foreground="#FFFFFF" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,10" Click="RemoveFirewallRules_Click" Cursor="Hand">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                        </Button>
                                        <Button Content="🔒 Enable LAN-Only Subnet Rule" Height="36" Padding="12,0" Background="#1E293B" Foreground="#38BDF8" BorderBrush="#38BDF8" BorderThickness="1" FontWeight="Bold" Margin="0,0,10,10" Click="ApplyLanSubnetRule_Click" Cursor="Hand">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                        </Button>
                                    </WrapPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="PUSH POLICIES TO CLIENT FLEET" Foreground="#F43F5E" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Transmit default firewall security policies to active workstation client endpoints over local network." Foreground="#94A3B8" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,15"/>
                                    <Button Content="⚡ Remote Sync Endpoint Rules" Width="220" Height="36" Background="#1E293B" Foreground="#38BDF8" BorderBrush="#38BDF8" BorderThickness="1" FontWeight="Bold" Click="RemoteSyncFirewall_Click" Cursor="Hand" HorizontalAlignment="Left">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Bottom Split: Rule Creation Panel + Live Rules List -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="400"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: Create Custom Rule -->
                            <Border Grid.Column="0" Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,15,0">
                                <StackPanel>
                                    <TextBlock Text="ADD / MODIFY CUSTOM FIREWALL RULE" Foreground="#F43F5E" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                                    
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Rule Name:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="RuleNameTxt" Text="ALAMS Custom Port" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Height="32" Padding="5,0,0,0" VerticalContentAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Port Number:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="RulePortTxt" Text="8080" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Height="32" Padding="5,0,0,0" VerticalContentAlignment="Center"/>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Protocol:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" x:Name="RuleProtoCombo" SelectedIndex="0" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Height="32">
                                            <ComboBoxItem Content="TCP"/>
                                            <ComboBoxItem Content="UDP"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Direction:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" x:Name="RuleDirectionCombo" SelectedIndex="0" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Height="32">
                                            <ComboBoxItem Content="Inbound"/>
                                            <ComboBoxItem Content="Outbound"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,0,0,15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Action:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                        <ComboBox Grid.Column="1" x:Name="RuleActionCombo" SelectedIndex="0" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Height="32">
                                            <ComboBoxItem Content="Allow"/>
                                            <ComboBoxItem Content="Block"/>
                                        </ComboBox>
                                    </Grid>

                                    <Button Content="➕ Apply Custom Firewall Rule" Height="36" Background="#38BDF8" Foreground="#0F172A" FontWeight="Bold" BorderThickness="0" Click="AddCustomRule_Click" Cursor="Hand" HorizontalAlignment="Stretch">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Right: Live Firewall Rules DataGrid / ListView -->
                            <Border Grid.Column="1" Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0" Margin="0,0,0,10">
                                        <TextBlock Text="ACTIVE ALAMS FIREWALL RULES" Foreground="#F43F5E" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Content="🔄 Refresh Rules List" Width="140" Height="28" Background="#1E293B" Foreground="#38BDF8" BorderBrush="#38BDF8" BorderThickness="1" FontWeight="Bold" FontSize="11" Click="RefreshFirewallRules_Click" Cursor="Hand" HorizontalAlignment="Right">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                                        </Button>
                                    </Grid>

                                    <ListBox Grid.Row="1" x:Name="FirewallRulesListBox" Background="#0F172A" Foreground="#F8FAFC" BorderBrush="#334155" FontFamily="Consolas" FontSize="12" Padding="5">
                                        <ListBoxItem Content="Click 'Refresh Rules List' to load active Windows Firewall rules."/>
                                    </ListBox>

                                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Content="🗑️ Remove Selected Rule" Height="32" Padding="12,0" Background="#7F1D1D" Foreground="#FCA5A5" FontWeight="Bold" BorderThickness="0" Click="RemoveSelectedRule_Click" Cursor="Hand">
                                            <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>


                <!-- TAB 3: BACKUP AND RECOVERY -->
                <TabItem Header="Backup">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Side: Triggers -->
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <Border Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                                <StackPanel>
                                    <TextBlock Text="CREATE RECOVERY CHECKPOINTS" Foreground="#F43F5E" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                                    
                                    <Button Content="💾 Backup PostgreSQL DB" Height="40" Background="#1E293B" Foreground="#38BDF8" BorderBrush="#38BDF8" BorderThickness="1" FontWeight="Bold" Margin="0,0,0,10" Click="BackupDb_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>

                                    <Button Content="📁 Backup Server Configs" Height="40" Background="#1E293B" Foreground="#94A3B8" BorderThickness="0" Margin="0,0,0,10" Click="BackupConfigs_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>

                                    <Border Background="#1E293B" Height="1" Margin="0,10,0,15"/>

                                    <TextBlock Text="RESET SYSTEM TO SEED CONFIG" Foreground="#F43F5E" FontSize="11" FontWeight="Bold" Margin="0,0,0,10"/>
                                    <Button Content="🧹 Fresh Seed Database" Height="36" Background="#7F1D1D" Foreground="#FCA5A5" BorderThickness="0" Click="FreshDbReset_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Right Side: Restore interface -->
                        <Border Grid.Column="1" Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="20">
                            <StackPanel>
                                <TextBlock Text="ONE-CLICK DISASTER RESTORE SYSTEM" Foreground="#F43F5E" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Text="Select a backup file from the local server backups directory and trigger a full PostgreSQL restore process." Foreground="#94A3B8" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,20"/>
                                
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Backup SQL File:" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="BackupFileNameTxt" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" Height="32" Padding="5,0,0,0" VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="2" Content="Browse..." Width="90" Height="32" Margin="10,0,0,0" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#475569" Click="BrowseBackup_Click" Cursor="Hand">
                                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                    </Button>
                                </Grid>

                                <Button Content="🔄 Run Full Database Restore" Height="40" Background="#F43F5E" Foreground="#FFFFFF" FontWeight="Bold" BorderThickness="0" Click="RestoreDb_Click" Cursor="Hand" HorizontalAlignment="Left" Width="240">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- TAB 4: EMBEDDED WEB PANEL -->
                <TabItem Header="WebPanel">
                    <Border Background="#020617" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" ClipToBounds="True">
                        <Grid x:Name="WebPanelContainer">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="🌐 ALAMS ADMIN WEB PORTAL GATEWAY" Foreground="#38BDF8" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Web Console running at http://localhost:3000" Foreground="#94A3B8" FontSize="13" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <Button Content="🚀 Launch Web Admin Console in Browser" Width="280" Height="42" Background="#0284C7" Foreground="#FFFFFF" FontWeight="Bold" FontSize="13" Click="OpenWebPortalBrowser_Click" Cursor="Hand">
                                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style></Button.Resources>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- LOCK OVERLAY SCREEN FOR ACCESS PROTECTION -->
        <Grid x:Name="LockOverlay" Grid.ColumnSpan="2" Background="#020617" Visibility="Visible">
            <Border Width="380" Height="280" Background="#0F172A" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="12" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="ALAMS COMMAND CENTER" Foreground="#F43F5E" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="ADMINISTRATIVE AUTHENTICATION" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,5,0,25" HorizontalAlignment="Center"/>
                    
                    <TextBlock Text="Enter Administrator Passcode:" Foreground="#94A3B8" FontSize="12.5" Margin="0,0,0,8"/>
