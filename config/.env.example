# =============================================================================
# ALAMS SERVER - TEMPLATE ENVIRONMENT CONFIGURATION
# Copy this file to "../server/.env" and fill in your connection details.
# =============================================================================

# --- SERVER RUNTIME ---
PORT=5000
NODE_ENV=production

# --- NEON POSTGRESQL (Cloud Database) ---
# Paste your Neon connection details here.
# DATABASE_URL  = Pooled connection (Express server connection)
# DIRECT_URL    = Direct connection (Prisma migrate/push connection)
DATABASE_URL="postgresql://user:password@ep-pooler.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-direct.region.aws.neon.tech/dbname?sslmode=require"

# --- SECURITY KEYS ---
# JWT_SECRET: Private key for signing access JSON Web Tokens (Admin/Faculty/Student)
JWT_SECRET="generate-a-secure-random-secret-key-for-jwt-signing"

# QR_SIGNING_KEY: HMAC key used to generate 2FA dynamic QR codes
QR_SIGNING_KEY="generate-a-secure-random-secret-key-for-qr-signing"

# WATCHDOG_SECRET: API key authentication token shared between Server and Windows Watchdog
WATCHDOG_SECRET="generate-a-secure-random-watchdog-key"

# --- CORS WHITELIST ---
# Comma-separated list of origins permitted to access APIs (e.g. Next.js port 3000)
CORS_ORIGINS="http://localhost:3000,http://localhost:5000"
