<Window x:Class="AlamsClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aurxon Lab Access Management" 
        Height="1080" Width="1920"
        WindowStyle="None" 
        WindowState="Maximized" 
        Topmost="True" 
        ResizeMode="NoResize" 
        ShowInTaskbar="False"
        Background="#FFFFFF"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Grid>
        <!-- Background decorative gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F0F9FF" Offset="0.4"/>
                <GradientStop Color="#E0F2FE" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Background decorative glows -->
        <Canvas>
            <Ellipse Width="600" Height="600" Fill="#0EA5E9" Opacity="0.1" Canvas.Left="-100" Canvas.Top="-100" Margin="0">
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="500" Height="500" Fill="#38BDF8" Opacity="0.15" Canvas.Right="-50" Canvas.Bottom="-50" Margin="0">
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid Margin="60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header and University Branding -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border Width="16" Height="16" CornerRadius="8" Background="#BE123C" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Symbiosis University of Applied Sciences, Indore" Foreground="#BE123C" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="SCSIT Department — ALAMS Access Portal" Foreground="#475569" FontSize="14" FontWeight="Medium" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Admin bypass icon in top-right -->
                <Button x:Name="AdminIconBtn" HorizontalAlignment="Right" VerticalAlignment="Center" Width="42" Height="42" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="AdminIcon_Click" ToolTip="Administrator Direct Access">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent">
                                <Ellipse Fill="#FFFFFF" Stroke="#CBD5E1" StrokeThickness="1.5">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#94A3B8" Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="🛡️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Main Work Area Split -->
            <Grid Grid.Row="1" Margin="0,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Column 0: Dynamic QR Code Authentication -->
                <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,15,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="4" Direction="270" Color="#93C5FD" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- PC Metadata & Header -->
                        <StackPanel Grid.Row="0">
                            <TextBlock x:Name="PcNumberText" Text="PC-00" Foreground="#0284C7" FontSize="36" FontWeight="Black"/>
                            <TextBlock x:Name="DeviceNameText" Text="Loading workstation configurations..." Foreground="#475569" FontSize="15" Margin="0,5,0,20" TextWrapping="Wrap"/>
                            <Separator Background="#F1F5F9" Margin="0,0,0,15"/>
                            <TextBlock Text="Mobile Scan Unlock" Foreground="#0F172A" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="Scan using ALAMS mobile app to authenticate instantly" Foreground="#475569" FontSize="14" Margin="0,5,0,0" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- QR Code Image -->
                        <Border Grid.Row="1" Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1.5" CornerRadius="12" Padding="15" VerticalAlignment="Center" HorizontalAlignment="Center" Width="230" Height="230">
                            <Grid>
                                <TextBlock x:Name="QrLoaderText" Text="Generating secure QR code..." Foreground="#64748B" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="10"/>
                                <Image x:Name="QrCodeImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- QR Refresh Progress Bar (using custom names to prevent compilation clash with OTP timer) -->
                        <StackPanel Grid.Row="2" x:Name="QrTimerPanel" Visibility="Visible">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="QR Code refresh interval" Foreground="#475569" FontSize="13"/>
                                <TextBlock x:Name="QrTimerText" Text="30s" Foreground="#0284C7" FontSize="13" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar x:Name="QrTimerProgressBar" Height="4" Background="#E2E8F0" Foreground="#0284C7" BorderThickness="0" Value="100" Maximum="100"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Column 1: Email OTP Authentication -->
                <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="10,0,10,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="4" Direction="270" Color="#93C5FD" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid Margin="30" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Email OTP Login" Foreground="#0F172A" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="Receive verification code on your registered email address" Foreground="#475569" FontSize="14" Margin="0,5,0,30" TextWrapping="Wrap"/>

                            <!-- Student Enrollment / Email Input -->
                            <TextBlock Text="ENROLLMENT NUMBER / EMAIL" Foreground="#475569" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="8" Padding="12,4" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,15">
                                <TextBox x:Name="OtpEnrollmentInput" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="18" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Send OTP Action -->
                            <Button x:Name="RequestOtpButton" Content="Request Verification Code" Background="#0284C7" Foreground="#FFFFFF" FontSize="15" FontWeight="Bold" Height="48" BorderThickness="0" Cursor="Hand" Click="RequestOtpButton_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8" />
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <!-- Verification Section (Hidden Initially) -->
                            <StackPanel x:Name="OtpVerificationPanel" Visibility="Collapsed" Margin="0,20,0,0">
                                <TextBlock Text="ENTER 6-DIGIT VERIFICATION CODE" Foreground="#475569" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                <Border Background="#F8FAFC" CornerRadius="8" Padding="12,4" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,20">
                                    <TextBox x:Name="OtpCodeInput" MaxLength="6" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="20" TextAlignment="Center" FontWeight="Bold" VerticalAlignment="Center"/>
                                </Border>

                                <Button x:Name="VerifyOtpButton" Content="Verify &amp; Unlock Workstation" Background="#10B981" Foreground="#FFFFFF" FontSize="15" FontWeight="Bold" Height="48" BorderThickness="0" Cursor="Hand" Click="VerifyOtpButton_Click">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8" />
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>

                            <!-- Expiry Countdown Indicator -->
                            <StackPanel x:Name="OtpTimerPanel" Visibility="Collapsed" Margin="0,20,0,0">
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="Verification code active lifetime" Foreground="#475569" FontSize="13"/>
                                    <TextBlock x:Name="TimerText" Text="60s" Foreground="#10B981" FontSize="13" HorizontalAlignment="Right" FontWeight="Bold"/>
                                </Grid>
                                <ProgressBar x:Name="QrProgressBar" Height="4" Background="#E2E8F0" Foreground="#10B981" BorderThickness="0" Value="100" Maximum="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Column 2: Enrollment + PIN Login Fallback -->
                <Border Grid.Column="2" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="15,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="4" Direction="270" Color="#93C5FD" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid Margin="30" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Workstation Fallback" Foreground="#0F172A" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Text="Unlock using your pre-configured local account credentials" Foreground="#475569" FontSize="14" Margin="0,5,0,30" TextWrapping="Wrap"/>

                            <!-- Enrollment Number Input -->
                            <TextBlock Text="ENROLLMENT NUMBER" Foreground="#475569" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="8" Padding="12,4" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,20">
                                <TextBox x:Name="EnrollmentInput" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="18" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Password Input -->
                            <TextBlock Text="ACCOUNT PASSWORD" Foreground="#475569" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="8" Padding="12,4" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,30">
                                <PasswordBox x:Name="PinInput" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="18" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Login Action -->
                            <Button x:Name="UnlockButton" Content="Unlock Workstation" Background="#0284C7" Foreground="#FFFFFF" FontSize="15" FontWeight="Bold" Height="48" BorderThickness="0" Cursor="Hand" Click="UnlockButton_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8" />
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <!-- Dynamic Status/Errors display -->
                            <TextBlock x:Name="StatusMessageText" Text="" Foreground="#EA580C" FontSize="14" Margin="0,20,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer / Net status -->
            <Grid Grid.Row="2">
                <TextBlock Text="Aurxon Lab Access Management System © 2026. Authorized users only." Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Neon Indicator Glows -->
                    <Ellipse x:Name="NetworkIndicator" Width="10" Height="10" Fill="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="NetworkIndicatorGlow" BlurRadius="8" Color="#EF4444" ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="NetworkStatusText" Text="OFFLINE" Foreground="#EF4444" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- PIN Verification Overlay Modal -->
        <Grid x:Name="PinOverlayGrid" Background="#900F172A" Visibility="Collapsed">
            <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Width="420" Height="320" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="#000000" Opacity="0.3" ShadowDepth="10"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="OverlayTitle" Text="🔒 2FA Verification" Foreground="#0F172A" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="OverlaySubtitle" Text="Enter the 6-digit session PIN shown on your mobile device." Foreground="#475569" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,25"/>
                    
                    <PasswordBox x:Name="OverlayOneTimePinInput" Width="220" Height="50" Background="#F8FAFC" Foreground="#0F172A" BorderBrush="#CBD5E1" BorderThickness="1.5" FontSize="26" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="6" Margin="0,0,0,25"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Margin="5" Height="40" Background="#E2E8F0" Foreground="#475569" FontWeight="Bold" Click="CancelPinOverlay_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="1" x:Name="VerifyOverlayPinButton" Content="Verify" Margin="5" Height="40" Background="#0284C7" Foreground="#FFFFFF" FontWeight="Bold" Click="VerifyOverlayPin_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
