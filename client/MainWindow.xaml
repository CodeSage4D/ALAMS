<Window x:Class="AlamsClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aurxon Lab Access Management" 
        Height="1080" Width="1920"
        WindowStyle="None" 
        WindowState="Maximized" 
        Topmost="True" 
        ResizeMode="NoResize" 
        ShowInTaskbar="False"
        Background="#FFFFFF"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Grid>
        <!-- Background decorative gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F0F9FF" Offset="0.4"/>
                <GradientStop Color="#E0F2FE" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Background decorative glows -->
        <Canvas>
            <Ellipse Width="600" Height="600" Fill="#0EA5E9" Opacity="0.1" Canvas.Left="-100" Canvas.Top="-100" Margin="0">
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="500" Height="500" Fill="#38BDF8" Opacity="0.15" Canvas.Right="-50" Canvas.Bottom="-50" Margin="0">
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid Margin="60">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header and University Branding -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border Width="16" Height="16" CornerRadius="8" Background="#BE123C" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Symbiosis University of Applied Sciences, Indore" Foreground="#BE123C" FontSize="24" FontWeight="Bold"/>
                        <TextBlock Text="SCSIT Department — ALAMS Access Portal" Foreground="#475569" FontSize="14" FontWeight="Medium" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Admin bypass icon in top-right -->
                <Button x:Name="AdminIconBtn" HorizontalAlignment="Right" VerticalAlignment="Center" Width="42" Height="42" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="AdminIcon_Click" ToolTip="Administrator Direct Access">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent">
                                <Ellipse Fill="#FFFFFF" Stroke="#CBD5E1" StrokeThickness="1.5">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#94A3B8" Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="🛡️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Main Work Area Split -->
            <Grid Grid.Row="1" Margin="0,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Pane: Dynamic QR Authentication -->
                <Border Grid.Column="0" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="0,0,30,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="4" Direction="270" Color="#93C5FD" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid Margin="40">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- PC Metadata -->
                        <StackPanel Grid.Row="0">
                            <TextBlock x:Name="PcNumberText" Text="PC-00" Foreground="#BE123C" FontSize="36" FontWeight="Black"/>
                            <TextBlock x:Name="DeviceNameText" Text="Loading workstation configurations..." Foreground="#475569" FontSize="16" Margin="0,5,0,0"/>
                        </StackPanel>

                        <!-- QR Code Area -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Background="#F8FAFC" Padding="20" CornerRadius="12" BorderBrush="#E2E8F0" BorderThickness="1">
                                <Grid Width="260" Height="260">
                                    <Image x:Name="QrCodeImage" Stretch="Uniform" />
                                    <!-- Fallback Loader while offline or syncing -->
                                    <TextBlock x:Name="QrLoaderText" Text="Connecting to central server..." Foreground="#475569" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="Scan QR to Unlock with Phone" Foreground="#BE123C" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,20,0,5"/>
                            <TextBlock Text="Use your standard mobile camera application" Foreground="#64748B" FontSize="14" HorizontalAlignment="Center"/>

                            <Button x:Name="ShowPinOverlayButton" Content="Enter Session PIN" Width="200" Height="40" Background="#F1F5F9" Foreground="#BE123C" BorderBrush="#BE123C" BorderThickness="1.5" FontWeight="Bold" FontSize="14" Margin="0,20,0,0" Click="ShowPinOverlayButton_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8" />
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                        <!-- Refresh countdown -->
                        <StackPanel Grid.Row="2">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="QR Code security lifecycle" Foreground="#475569" FontSize="13"/>
                                <TextBlock x:Name="TimerText" Text="30s" Foreground="#BE123C" FontSize="13" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>
                            <ProgressBar x:Name="QrProgressBar" Height="4" Background="#E2E8F0" Foreground="#BE123C" BorderThickness="0" Value="100" Maximum="100"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Right Pane: Enrollment + PIN Login Fallback -->
                <Border Grid.Column="1" Background="#FFFFFF" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Margin="30,0,0,0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="25" ShadowDepth="4" Direction="270" Color="#93C5FD" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid Margin="40" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="Workstation Fallback" Foreground="#BE123C" FontSize="26" FontWeight="Bold"/>
                            <TextBlock Text="Access computer via local account PIN credentials" Foreground="#475569" FontSize="15" Margin="0,5,0,30"/>

                            <!-- Enrollment Number Input -->
                            <TextBlock Text="ENROLLMENT NUMBER" Foreground="#BE123C" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="8" Padding="12,4" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,20">
                                <TextBox x:Name="EnrollmentInput" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="18" VerticalAlignment="Center"/>
                            </Border>

                            <!-- PIN Input -->
                            <TextBlock Text="6-DIGIT PASSCODE / PIN" Foreground="#BE123C" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                            <Border Background="#F8FAFC" CornerRadius="8" Padding="12,4" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,30">
                                <PasswordBox x:Name="PinInput" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="18" VerticalAlignment="Center" MaxLength="6"/>
                            </Border>

                            <!-- Login Action -->
                            <Button x:Name="UnlockButton" Content="Unlock Workstation" Background="#BE123C" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" Height="50" BorderThickness="0" Cursor="Hand" Click="UnlockButton_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8" />
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <!-- Dynamic Status/Errors display -->
                            <TextBlock x:Name="StatusMessageText" Text="" Foreground="#EF4444" FontSize="14" Margin="0,20,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Footer / Net status -->
            <Grid Grid.Row="2">
                <TextBlock Text="Aurxon Lab Access Management System © 2026. Authorized users only." Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Neon Indicator Glows -->
                    <Ellipse x:Name="NetworkIndicator" Width="10" Height="10" Fill="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="NetworkIndicatorGlow" BlurRadius="8" Color="#EF4444" ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="NetworkStatusText" Text="OFFLINE" Foreground="#EF4444" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- PIN Verification Overlay Modal -->
        <Grid x:Name="PinOverlayGrid" Background="#900F172A" Visibility="Collapsed">
            <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Width="420" Height="320" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="#000000" Opacity="0.3" ShadowDepth="10"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="OverlayTitle" Text="🔒 2FA Verification" Foreground="#BE123C" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="OverlaySubtitle" Text="Enter the 6-digit session PIN shown on your mobile device." Foreground="#475569" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,25"/>
                    
                    <PasswordBox x:Name="OverlayOneTimePinInput" Width="220" Height="50" Background="#F8FAFC" Foreground="#0F172A" BorderBrush="#CBD5E1" BorderThickness="1.5" FontSize="26" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="6" Margin="0,0,0,25"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Margin="5" Height="40" Background="#E2E8F0" Foreground="#475569" FontWeight="Bold" Click="CancelPinOverlay_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="1" x:Name="VerifyOverlayPinButton" Content="Verify" Margin="5" Height="40" Background="#BE123C" Foreground="#FFFFFF" FontWeight="Bold" Click="VerifyOverlayPin_Click">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
