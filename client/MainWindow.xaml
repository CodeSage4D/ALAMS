<Window x:Class="AlamsClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aurxon Lab Access Management" 
        Height="1080" Width="1920"
        WindowStyle="None" 
        WindowState="Maximized" 
        Topmost="True" 
        ResizeMode="NoResize" 
        ShowInTaskbar="False"
        Background="#FFFFFF"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    
    <Grid>
        <!-- Background decorative premium gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFFFFF" Offset="0"/>
                <GradientStop Color="#F8FAFC" Offset="0.3"/>
                <GradientStop Color="#EEF2F6" Offset="0.7"/>
                <GradientStop Color="#E0F2FE" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Background decorative ambient glow elements -->
        <Canvas>
            <Ellipse Width="800" Height="800" Fill="#0EA5E9" Opacity="0.08" Canvas.Left="-200" Canvas.Top="-200" Margin="0">
                <Ellipse.Effect>
                    <BlurEffect Radius="200"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="600" Height="600" Fill="#6366F1" Opacity="0.08" Canvas.Right="-100" Canvas.Bottom="-100" Margin="0">
                <Ellipse.Effect>
                    <BlurEffect Radius="200"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid Margin="60,40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header and Branding -->
            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border Width="18" Height="18" CornerRadius="9" Background="#BE123C" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Symbiosis University of Applied Sciences, Indore" Foreground="#BE123C" FontSize="26" FontWeight="ExtraBold"/>
                        <TextBlock Text="SCSIT Department — ALAMS Access Control Portal" Foreground="#64748B" FontSize="14" FontWeight="SemiBold" Margin="0,3,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Admin Bypass Button -->
                <Button x:Name="AdminIconBtn" HorizontalAlignment="Right" VerticalAlignment="Center" Width="44" Height="44" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="AdminIcon_Click" ToolTip="Administrator Direct Access">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid Background="Transparent">
                                <Ellipse Fill="#FFFFFF" Stroke="#E2E8F0" StrokeThickness="1.5">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#94A3B8" Opacity="0.25"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock Text="🛡️" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Main Work Split Area -->
            <Grid Grid.Row="1" Margin="0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Minimal QR Code Area -->
                <Grid Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,0,40,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,30" HorizontalAlignment="Center">
                        <TextBlock x:Name="PcNumberText" Text="PC-00" Foreground="#0284C7" FontSize="54" FontWeight="Black" TextAlignment="Center"/>
                        <TextBlock x:Name="DeviceNameText" Text="Loading configuration..." Foreground="#475569" FontSize="16" FontWeight="Medium" TextAlignment="Center" Margin="0,5,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- QR Code Border Box -->
                    <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="20" Padding="35" Width="310" Height="310" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="30" ShadowDepth="6" Direction="270" Color="#0EA5E9" Opacity="0.15"/>
                        </Border.Effect>
                        <Grid>
                            <TextBlock x:Name="QrLoaderText" Text="Generating secure QR code..." Foreground="#64748B" FontSize="14" FontWeight="Medium" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="10"/>
                            <Image x:Name="QrCodeImage" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Refresh timer underneath -->
                    <StackPanel Grid.Row="2" x:Name="QrTimerPanel" Margin="0,30,0,0" Width="310" HorizontalAlignment="Center">
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Security token lifecycle" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="QrTimerText" Text="30s" Foreground="#0284C7" FontSize="13" HorizontalAlignment="Right" FontWeight="Bold"/>
                        </Grid>
                        <ProgressBar x:Name="QrTimerProgressBar" Height="5" Background="#E2E8F0" Foreground="#0284C7" BorderThickness="0" Value="100" Maximum="100">
                            <ProgressBar.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="2.5"/></Style>
                            </ProgressBar.Resources>
                        </ProgressBar>
                    </StackPanel>
                </Grid>

                <!-- Right Panel: Glassmorphic Auth & Diagnostics -->
                <Grid Grid.Column="1" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Login Cards (Glassmorphism design) -->
                    <Border Grid.Row="0" VerticalAlignment="Center" Background="#D8FFFFFF" CornerRadius="24" BorderBrush="#80E2E8F0" BorderThickness="1.5" Padding="40,30">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="45" ShadowDepth="12" Direction="270" Color="#94A3B8" Opacity="0.2"/>
                        </Border.Effect>
                        <Grid>
                            <TabControl x:Name="AuthTabControl" Background="Transparent" BorderThickness="0">
                                <TabControl.Resources>
                                    <!-- Hide Tab Headers since we default to Credentials login -->
                                    <Style TargetType="TabItem">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </Style>
                                </TabControl.Resources>

                                <!-- Tab 1: Credentials Login (Default) -->
                                <TabItem Selector.IsSelected="True">
                                    <StackPanel>
                                        <TextBlock Text="Workstation Authentication" Foreground="#0F172A" FontSize="26" FontWeight="Bold" Margin="0,0,0,6"/>
                                        <TextBlock Text="Enter your Symbiosis credentials to authorize access." Foreground="#64748B" FontSize="14" FontWeight="Medium" Margin="0,0,0,30"/>

                                        <!-- Email/Enrollment -->
                                        <TextBlock Text="COLLEGE EMAIL / ENROLLMENT NUMBER" Foreground="#475569" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Border Background="#F8FAFC" CornerRadius="10" Padding="14,6" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,20">
                                            <TextBox x:Name="EnrollmentInput" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Password -->
                                        <TextBlock Text="SECURE ACCOUNT PASSWORD" Foreground="#475569" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Border Background="#F8FAFC" CornerRadius="10" Padding="14,6" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,15">
                                            <PasswordBox x:Name="PinInput" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="18" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Offline access checkbox -->
                                        <CheckBox x:Name="OfflineAccessCheckbox" Margin="0,0,0,25" Cursor="Hand">
                                            <CheckBox.Template>
                                                <ControlTemplate TargetType="CheckBox">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Grid Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center">
                                                            <Border x:Name="Box" CornerRadius="4" BorderBrush="#CBD5E1" BorderThickness="2" Background="#FFFFFF"/>
                                                            <TextBlock x:Name="Check" Text="✔" Foreground="#0284C7" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                        </Grid>
                                                        <TextBlock Text="Offline Access (verify using administrator-issued PIN)" Foreground="#475569" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="Box" Property="BorderBrush" Value="#0284C7"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </CheckBox.Template>
                                        </CheckBox>

                                        <!-- Actions -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0" x:Name="UnlockButton" Content="Unlock Workstation" Background="#0284C7" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" Height="50" BorderThickness="0" Cursor="Hand" Click="UnlockButton_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- Toggle OTP Tab -->
                                            <Button Grid.Column="1" x:Name="ToggleOtpBtn" Margin="15,0,0,0" Width="50" Height="50" Background="#F1F5F9" BorderThickness="0" Cursor="Hand" Click="ToggleOtpTab_Click" ToolTip="Request Email OTP">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="#E2E8F0" BorderThickness="1">
                                                            <TextBlock Text="✉️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>

                                        <!-- Switch to PIN code display modal -->
                                        <Button x:Name="ShowPinOverlayButton" Content="Click to Enter Session PIN" Margin="0,15,0,0" Background="Transparent" BorderThickness="0" Foreground="#0284C7" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="ShowPinOverlayButton_Click"/>

                                        <!-- Dynamic status display -->
                                        <TextBlock x:Name="StatusMessageText" Text="" Foreground="#EA580C" FontSize="14" FontWeight="SemiBold" Margin="0,15,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </TabItem>

                                <!-- Tab 2: Email OTP Login -->
                                <TabItem>
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="Email OTP Login" Foreground="#0F172A" FontSize="26" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <Button HorizontalAlignment="Right" Content="✕ Go Back" Foreground="#64748B" Background="Transparent" BorderThickness="0" FontSize="14" FontWeight="Bold" Cursor="Hand" Click="GoBackToCredentials_Click"/>
                                        </Grid>
                                        <TextBlock Text="Request a secure verification code to your university email address." Foreground="#64748B" FontSize="14" FontWeight="Medium" Margin="0,0,0,30"/>

                                        <!-- Student Enrollment / Email Input -->
                                        <TextBlock Text="ENROLLMENT NUMBER / EMAIL" Foreground="#475569" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                        <Border Background="#F8FAFC" CornerRadius="10" Padding="14,6" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,20">
                                            <TextBox x:Name="OtpEnrollmentInput" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Send OTP Action -->
                                        <Button x:Name="RequestOtpButton" Content="Request Verification Code" Background="#0284C7" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" Height="50" BorderThickness="0" Cursor="Hand" Click="RequestOtpButton_Click">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <!-- Verification Code entry -->
                                        <StackPanel x:Name="OtpVerificationPanel" Visibility="Collapsed" Margin="0,25,0,0">
                                            <TextBlock Text="ENTER 6-DIGIT VERIFICATION CODE" Foreground="#475569" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                                            <Border Background="#F8FAFC" CornerRadius="10" Padding="14,6" BorderBrush="#CBD5E1" BorderThickness="1" Margin="0,0,0,20">
                                                <TextBox x:Name="OtpCodeInput" MaxLength="6" Background="Transparent" Foreground="#0F172A" BorderThickness="0" FontSize="22" TextAlignment="Center" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Border>

                                            <Button x:Name="VerifyOtpButton" Content="Verify &amp; Unlock Workstation" Background="#10B981" Foreground="#FFFFFF" FontSize="16" FontWeight="Bold" Height="50" BorderThickness="0" Cursor="Hand" Click="VerifyOtpButton_Click">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </StackPanel>

                                        <!-- Expiry Countdown Indicator -->
                                        <StackPanel x:Name="OtpTimerPanel" Visibility="Collapsed" Margin="0,25,0,0">
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Verification token validity" Foreground="#64748B" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="TimerText" Text="60s" Foreground="#10B981" FontSize="13" HorizontalAlignment="Right" FontWeight="Bold"/>
                                            </Grid>
                                            <ProgressBar x:Name="QrProgressBar" Height="5" Background="#E2E8F0" Foreground="#10B981" BorderThickness="0" Value="100" Maximum="100">
                                                <ProgressBar.Resources>
                                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="2.5"/></Style>
                                                </ProgressBar.Resources>
                                            </ProgressBar>
                                        </StackPanel>
                                    </StackPanel>
                                </TabItem>
                            </TabControl>
                        </Grid>
                    </Border>

                    <!-- Real-Time Network & Connection Diagnostics Panel -->
                    <Border Grid.Row="1" Background="#80F8FAFC" CornerRadius="16" BorderBrush="#E2E8F0" BorderThickness="1" Padding="25,20" Margin="0,30,0,0">
                        <StackPanel>
                            <TextBlock Text="📡 Workstation Telemetry &amp; Network Status" Foreground="#0F172A" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                            <UniformGrid Columns="3" Rows="2">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="WEBSOCKET STATUS" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="DiagWsStatusText" Text="DISCONNECTED" Foreground="#EF4444" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="LATENCY" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="DiagLatencyText" Text="N/A" Foreground="#475569" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="LAST HEARTBEAT" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="DiagHeartbeatText" Text="N/A" Foreground="#475569" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="LAST SYNC TIME" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="DiagSyncText" Text="Never" Foreground="#475569" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="CONNECTION QUALITY" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="DiagConnQualityText" Text="Offline" Foreground="#64748B" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="NETWORK HEALTH" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="0,0,0,3"/>
                                    <TextBlock x:Name="DiagNetHealthText" Text="OFFLINE" Foreground="#EF4444" FontSize="13" FontWeight="Bold"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Footer -->
            <Grid Grid.Row="2">
                <TextBlock Text="Aurxon Lab Access Management System © 2026. Authorized users only." Foreground="#64748B" FontSize="12" VerticalAlignment="Center" FontWeight="Medium"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse x:Name="NetworkIndicator" Width="10" Height="10" Fill="#EF4444" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="NetworkIndicatorGlow" BlurRadius="8" Color="#EF4444" ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="NetworkStatusText" Text="OFFLINE" Foreground="#EF4444" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- PIN Verification Overlay Modal -->
        <Grid x:Name="PinOverlayGrid" Background="#900F172A" Visibility="Collapsed">
            <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="16" Width="420" Height="320" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" Color="#000000" Opacity="0.3" ShadowDepth="10"/>
                </Border.Effect>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="OverlayTitle" Text="🔒 2FA Verification" Foreground="#0F172A" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="OverlaySubtitle" Text="Enter the 6-digit session PIN shown on your mobile device." Foreground="#475569" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,25"/>
                    
                    <PasswordBox x:Name="OverlayOneTimePinInput" Width="220" Height="50" Background="#F8FAFC" Foreground="#0F172A" BorderBrush="#CBD5E1" BorderThickness="1.5" FontSize="26" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="6" Margin="0,0,0,25"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Margin="5" Height="40" Background="#E2E8F0" Foreground="#475569" FontWeight="Bold" Click="CancelPinOverlay_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="1" x:Name="VerifyOverlayPinButton" Content="Verify" Margin="5" Height="40" Background="#0284C7" Foreground="#FFFFFF" FontWeight="Bold" Click="VerifyOverlayPin_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
