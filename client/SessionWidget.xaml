<Window x:Class="AlamsClient.SessionWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ALAMS Session Widget" 
        Height="80" Width="360"
        WindowStyle="None" 
        Topmost="True" 
        ResizeMode="NoResize" 
        ShowInTaskbar="False"
        Background="#1F2937"
        AllowsTransparency="True"
        CornerRadius="8"
        BorderBrush="#374151"
        BorderThickness="1.5"
        WindowStartupLocation="Manual"
        Left="30" Top="30"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <Grid Margin="15,10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Session Status Info -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="EnrollmentText" Text="Student: ENR001" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold"/>
            </StackPanel>
            <TextBlock x:Name="ElapsedText" Text="Logged in: 0 mins" Foreground="#9CA3AF" FontSize="12" Margin="16,4,0,0"/>
        </StackPanel>

        <!-- Logout Button -->
        <Button Grid.Column="1" x:Name="LogoutButton" Content="Log Out" Background="#EF4444" Foreground="#FFFFFF" FontSize="13" FontWeight="Bold" Width="90" Height="36" BorderThickness="0" Cursor="Hand" Click="LogoutButton_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6" />
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
